{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "outDir": ".tsc-out",
    "rootDir": "."
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", ".tsc-out", "playwright-report", "test-results"]
}
